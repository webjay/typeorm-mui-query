{
  "name": "typeorm-mui-query",
  "version": "1.3.0",
  "description": "MUI TypeORM QueryBuilder",
  "keywords": [
    "MUI",
    "TypeORM"
  ],
  "license": "MIT",
  "main": "output/main.js",
  "module": "output/main.mjs",
  "types": "output/main.d.ts",
  "files": [
    "output"
  ],
  "scripts": {
    "build": "rollup -c",
    "predeploy": "npm run lint && npm run test && npm run build",
